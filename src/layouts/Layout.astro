---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  lang?: string;
}

const { title, description, lang = 'de' } = Astro.props;
const baseUrl = 'https://properflow.ch';
const isDe = lang !== 'en';
const ogLocale = isDe ? 'de_CH' : 'en_GB';
const ogLocaleAlternate = isDe ? 'en_GB' : 'de_CH';
const canonicalUrl = isDe ? baseUrl : `${baseUrl}/en`;
// TODO: replace with a real 1200×630 PNG/JPG at public/og-image.png for social previews.
const ogImage: string | null = null;
const logoUrl = `${baseUrl}/assets/florian-fackler-logo.png`;

// Localized strings for OG / Twitter / JSON-LD
const copy = isDe
  ? {
      ogTitle: 'Florian Fackler | KI-Automatisierung für Schweizer KMU',
      ogDescription:
        'Datenschutzkonforme KI-Automatisierung für Schweizer KMU. Dokumentenverarbeitung, Workflow-Automatisierung und intelligente Assistenten. Ihre Daten bleiben in der Schweiz.',
      orgDescription:
        'Datenschutzkonforme KI-Automatisierung für Schweizer KMU.',
      serviceDescription:
        'KI-Automatisierung für Schweizer KMU. Datenschutzkonforme Dokumentenverarbeitung, Workflow-Automatisierung und intelligente Assistenten.',
      webPageName: 'Florian Fackler | KI-Automatisierung für Schweizer KMU',
      webPageDescription:
        'Datenschutzkonforme KI-Automatisierung für Schweizer KMU. Dokumentenverarbeitung, Workflow-Automatisierung und intelligente Assistenten.',
      inLanguage: 'de-CH',
      serviceTypes: [
        'KI-Dokumentenverarbeitung',
        'Workflow-Automatisierung',
        'Datenschutzkonforme KI-Beratung',
        'Geschäftsprozess-Automatisierung',
      ],
      offers: [
        {
          name: 'Setup',
          description:
            'Hardware, KI-Software-Einrichtung, erster automatisierter Workflow und Team-Schulung.',
          price: '3000',
          priceMax: '8000',
        },
        {
          name: 'Monatlicher Support',
          description:
            'Laufender Betrieb, KI-Verbesserungen, Workflow-Anpassungen und priorisierter Support.',
          price: '300',
          priceMax: '800',
        },
        {
          name: 'Projektbasis',
          description:
            'Individuelle Automatisierung für einen konkreten Geschäftsprozess – Dokumenten-KI, Chatbot, E-Mail-Bearbeitung.',
          price: '2000',
          priceMax: '10000',
        },
      ],
    }
  : {
      ogTitle: 'Florian Fackler | AI Automation for Swiss SMEs',
      ogDescription:
        'Privacy-focused AI automation for Swiss SMEs. Document processing, workflow automation, and intelligent assistants. Your data stays in Switzerland.',
      orgDescription: 'Privacy-focused AI automation for Swiss SMEs.',
      serviceDescription:
        'AI automation for Swiss SMEs. Privacy-focused document processing, workflow automation, and intelligent assistants.',
      webPageName: 'Florian Fackler | AI Automation for Swiss SMEs',
      webPageDescription:
        'Privacy-focused AI automation for Swiss SMEs. Document processing, workflow automation, intelligent assistants.',
      inLanguage: 'en',
      serviceTypes: [
        'AI Document Processing',
        'Workflow Automation',
        'Privacy-Focused AI Consulting',
        'Business Process Automation',
      ],
      offers: [
        {
          name: 'Setup',
          description:
            'Hardware, AI software setup, your first automated workflow, and team training.',
          price: '3000',
          priceMax: '8000',
        },
        {
          name: 'Monthly Support',
          description:
            'Ongoing operation, AI improvements, workflow adjustments, and priority support.',
          price: '300',
          priceMax: '800',
        },
        {
          name: 'Per Project',
          description:
            'Custom automation for a specific business process — document AI, chatbot, email handling.',
          price: '2000',
          priceMax: '10000',
        },
      ],
    };

const jsonLd = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Organization',
      '@id': `${baseUrl}/#organization`,
      name: 'Florian Fackler IT Services',
      url: `${baseUrl}/`,
      logo: logoUrl,
      description: copy.orgDescription,
      legalName: 'Florian Fackler IT Services',
      foundingDate: '2026',
      address: {
        '@type': 'PostalAddress',
        streetAddress: 'Bumelochstrasse 35',
        addressLocality: 'Starrkirch-Wil',
        postalCode: '4656',
        addressRegion: 'SO',
        addressCountry: 'CH',
      },
    },
    {
      '@type': 'WebSite',
      '@id': `${baseUrl}/#website`,
      url: `${baseUrl}/`,
      name: 'Florian Fackler IT Services',
      publisher: { '@id': `${baseUrl}/#organization` },
      inLanguage: ['de-CH', 'en'],
    },
    {
      '@type': 'WebPage',
      '@id': `${canonicalUrl}#webpage`,
      url: canonicalUrl,
      name: copy.webPageName,
      description: copy.webPageDescription,
      isPartOf: { '@id': `${baseUrl}/#website` },
      about: { '@id': `${baseUrl}/#organization` },
      inLanguage: copy.inLanguage,
    },
    {
      '@type': 'ProfessionalService',
      name: 'Florian Fackler IT Services',
      url: `${baseUrl}/`,
      description: copy.serviceDescription,
      priceRange: 'CHF 300 - 10000',
      areaServed: {
        '@type': 'GeoCircle',
        geoMidpoint: {
          '@type': 'GeoCoordinates',
          latitude: 47.3539,
          longitude: 7.9081,
        },
        geoRadius: '80000',
      },
      serviceType: copy.serviceTypes,
      knowsAbout: [
        'Artificial Intelligence',
        'Workflow Automation',
        'Business Process Automation',
        'Data Privacy',
        'Document Processing',
        'n8n',
        'Ollama',
        'Large Language Models',
      ],
      hasOfferCatalog: {
        '@type': 'OfferCatalog',
        name: 'AI Automation Packages',
        itemListElement: copy.offers.map((offer) => ({
          '@type': 'Offer',
          itemOffered: {
            '@type': 'Service',
            name: offer.name,
            description: offer.description,
          },
          priceSpecification: {
            '@type': 'PriceSpecification',
            minPrice: offer.price,
            maxPrice: offer.priceMax,
            priceCurrency: 'CHF',
          },
        })),
      },
    },
  ],
};
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <!-- Favicons -->
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon-48x48.png" />
    <link rel="icon" type="image/x-icon" href="/assets/favicon-dark.ico" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-dark-16x16.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-dark-32x32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="48x48" href="/assets/favicon-dark-48x48.png" media="(prefers-color-scheme: dark)" />
    <!-- Open Graph -->
    <meta property="og:title" content={copy.ogTitle} />
    <meta property="og:description" content={copy.ogDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:locale:alternate" content={ogLocaleAlternate} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content="Florian Fackler" />
    {ogImage && (
      <>
        <meta property="og:image" content={ogImage} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={copy.ogTitle} />
      </>
    )}
    <!-- Twitter Card -->
    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={copy.ogTitle} />
    <meta name="twitter:description" content={copy.ogDescription} />
    {ogImage && <meta name="twitter:image" content={ogImage} />}
    <!-- Geo -->
    <meta name="geo.region" content="CH-SO" />
    <meta name="geo.placename" content="Starrkirch-Wil" />
    <!-- Robots -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <!-- Canonical -->
    <link rel="canonical" href={canonicalUrl} />
    <!-- Alternate languages -->
    <link rel="alternate" hreflang="de" href={baseUrl} />
    <link rel="alternate" hreflang="en" href={`${baseUrl}/en`} />
    <link rel="alternate" hreflang="x-default" href={baseUrl} />
    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />

    <script is:inline>
      const htmlElement = document.documentElement;

      function setTheme(theme) {
        htmlElement.setAttribute("data-theme", theme);
        localStorage.setItem("theme", theme);
      }

      const saved = localStorage.getItem("theme");
      const prefersDark = window.matchMedia(
        "(prefers-color-scheme: dark)",
      ).matches;
      setTheme(saved || (prefersDark ? "dark" : "light"));

      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const current = htmlElement.getAttribute("data-theme");
        setTheme(current === "dark" ? "light" : "dark");
      });

      window
        .matchMedia("(prefers-color-scheme: dark)")
        .addEventListener("change", (e) => {
          if (!localStorage.getItem("theme")) {
            setTheme(e.matches ? "dark" : "light");
          }
        });
    </script>
  </body>
</html>
