---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ContactDialog from '../components/ContactDialog.astro';
import de from '../i18n/locales/de/index.json';

const t = (key: string) => {
  const keys = key.split('.');
  let value: unknown = de;
  for (const k of keys) {
    if (value && typeof value === 'object' && k in value) {
      value = (value as Record<string, unknown>)[k];
    } else {
      return key;
    }
  }
  return typeof value === 'string' ? value : key;
};
---

<Layout 
  title={de.title}
  description={de.description}
  lang="de"
>
  <Header lang="de" />
  
  <!-- Hero Section -->
  <section class="hero">
    <div class="container">
      <div class="hero-layout">
        <div class="hero-text">
          <h1>{de.hero_headline}</h1>
          <p set:html={de.hero_tagline} />
          <div class="hero-meta">
            <span class="hero-rate">ab CHF 150/h</span>
            <span class="hero-divider">·</span>
            <span class="hero-avail">Verfügbar – Antwort innerhalb 24h</span>
          </div>
          <button type="button" class="btn" onclick="openContactDialog()">
            {de.contact_cta}
          </button>
        </div>
        <div class="hero-photo">
          <picture>
            <source srcset="/assets/lilaflo.avif" type="image/avif" />
            <source srcset="/assets/lilaflo.webp" type="image/webp" />
            <img src="/assets/lilaflo.png" alt="Florian Fackler" width="280" />
          </picture>
        </div>
      </div>
    </div>
  </section>
  
  <!-- USP Section -->
  <section>
    <div class="container">
      <h2>{de.usp_title}</h2>
      <div class="usp-grid">
        <div>
          <h3>{de.usp_1_title}</h3>
          <p set:html={de.usp_1_text.replace(/\n/g, '<br/><br/>')} />
        </div>
        <div>
          <h3>{de.usp_2_title}</h3>
          <ul>
            {de.usp_2_list.map((item: string) => <li set:html={item} />)}
          </ul>
        </div>
        <div>
          <h3>{de.usp_3_title}</h3>
          <ul>
            {de.usp_3_list.map((item: string) => <li set:html={item} />)}
          </ul>
        </div>
      </div>
    </div>
  </section>
  
  <!-- References -->
  <section id="references">
    <div class="container">
      <h2>{de.references_title}</h2>
      <p class="references-intro">{de.references_intro}</p>
      <div class="references-grid">
        {de.references.map((ref: { client: string; project: string; result: string; tags: string[] }) => (
          <div class="reference-card">
            <div class="ref-header">
              <span class="ref-client">{ref.client}</span>
              <div class="ref-tags">
                {ref.tags.map((tag: string) => <span class="ref-tag">{tag}</span>)}
              </div>
            </div>
            <h3>{ref.project}</h3>
            <p>{ref.result}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

    <!-- Industries -->
  <section id="industries" class="section-alt">
    <div class="container">
      <h2>{de.industries_title}</h2>
      <div class="services-grid">
        {de.industry_cards.map((card: { title: string; text: string }) => (
          <div class="service-card">
            <h3 set:html={card.title} />
            <p set:html={card.text} />
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <!-- Services -->
  <section id="services">
    <div class="container">
      <h2>{de.services_title}</h2>
      <div class="services-grid">
        {de.service_cards.map((card: { title: string; text: string; details: string[] }) => (
          <div class="service-card">
            <h3 set:html={card.title} />
            <p set:html={card.text} />
            <ul>
              {card.details.map((detail: string) => <li set:html={detail} />)}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>
  
  <section id="pricing" class="section-alt">
    <div class="container">
      <h2>{de.pricing_title}</h2>
      <div class="services-grid">
        {de.pricing_cards.map((card: { title: string; price: string; price_note: string; details: string[] }) => (
          <div class="service-card">
            <h3>{card.title}</h3>
            <p class="price">{card.price}</p>
            <p class="price-note">{card.price_note}</p>
            <ul>
              {card.details.map((detail: string) => <li set:html={detail} />)}
            </ul>
          </div>
        ))}
      </div>

      <div class="day-rates">
        <h3>{de.day_rates_title}</h3>
        <div class="day-rates-grid">
          {de.day_rates.map((item: { label: string; rate: string }) => (
            <div class="day-rate-row">
              <span class="day-rate-label">{item.label}</span>
              <span class="day-rate-value">{item.rate}</span>
            </div>
          ))}
        </div>
      </div>

      <div style="text-align: center; margin-top: 40px">
        <p set:html={de.pricing_note} />
      </div>
    </div>
  </section>
  
  <!-- Contact -->
  <section id="contact">
    <div class="container">
      <h2>{de.contact_title}</h2>
      <p set:html={de.contact_subtitle} />
      <br />
      <button type="button" class="btn" onclick="openContactDialog()">
        {de.contact_cta}
      </button>
    </div>
  </section>
  
  <ContactDialog lang="de" />
  <Footer lang="de" />
</Layout>
