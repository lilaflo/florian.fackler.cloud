---
const currentYear = new Date().getFullYear();
---

<footer>
  <div class="container footer-flex">
    <div>
      <p>
        © <span id="year">{currentYear}</span> Florian Fackler. All rights reserved.
      </p>
      <p>
        AI Solutions • Systems &amp; Strategy • Online Shops • Interim IT
        Leadership
      </p>
    </div>
    <div class="trust-element">
      <span>Swiss Quality</span>
      <!-- Swiss Flag -->
      <svg
        width="30"
        height="30"
        viewBox="0 0 32 32"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect width="32" height="32" fill="var(--accent)"></rect>
        <rect x="6" y="13" width="20" height="6" fill="var(--white)"></rect>
        <rect x="13" y="6" width="6" height="20" fill="var(--white)"></rect>
      </svg>
    </div>
  </div>
</footer>
