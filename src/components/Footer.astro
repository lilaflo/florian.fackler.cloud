---
interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

const translations = {
  en: {
    copyright: `© ${new Date().getFullYear()} Florian Fackler. All rights reserved.`,
    services: 'AI Solutions • Systems & Strategy • Online Shops • Interim IT Leadership',
    swissQuality: 'Swiss Quality',
  },
  de: {
    copyright: `© ${new Date().getFullYear()} Florian Fackler. Alle Rechte vorbehalten.`,
    services: 'KI-Lösungen • Systeme & Strategie • Online-Shops • Interim IT-Leitung',
    swissQuality: 'Swiss Quality',
  },
};

const t = translations[lang as keyof typeof translations] || translations.en;
---

<footer>
  <div class="container footer-flex">
    <div>
      <p set:html={t.copyright} />
      <p>{t.services}</p>
      <div class="lang-switch">
        <a href="/">EN</a>
        <span>|</span>
        <a href="/de">DE</a>
      </div>
    </div>
    <div class="trust-element">
      <span>{t.swissQuality}</span>
      <svg
        width="30"
        height="30"
        viewBox="0 0 32 32"
        xmlns="http://www.w3.org/2000/svg"
      >
        <rect width="32" height="32" fill="var(--accent)"></rect>
        <rect x="6" y="13" width="20" height="6" fill="var(--white)"></rect>
        <rect x="13" y="6" width="6" height="20" fill="var(--white)"></rect>
      </svg>
    </div>
  </div>
</footer>